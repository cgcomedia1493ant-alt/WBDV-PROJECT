        <div class="md:w-1/2 relative min-h-[250px] md:h-auto overflow-hidden">
             <img src="https://www.patpat.com/cdn/shop/files/67bee3d913123.webp?v=1755141402" class="w-full h-full object-cover transition-transform duration-[10s] hover:scale-110" alt="Boutique visual" onerror="this.src='https://images.unsplash.com/photo-1544441893-675973e31985?q=80&w=800'">
