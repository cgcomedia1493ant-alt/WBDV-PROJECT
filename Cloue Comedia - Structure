                    <img src="https://www.patpat.com/cdn/shop/files/0_3138c578-8451-474e-bb00-63a08c1c0a5a.jpg?v=1774492566" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt="Family 1" onerror="this.src='https://images.unsplash.com/photo-1511895426328-dc8714191300?q=80&w=800'">
                </div>
                <div class="glass-card p-0 rounded-[40px] aspect-[3/4.2] overflow-hidden cursor-pointer group shadow-xl">
                    <img src="https://www.patpat.com/cdn/shop/files/01_aa33d283-016d-4446-88dd-7dd1180361ab.jpg?v=1773136725" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt="Family 2" onerror="this.src='https://images.unsplash.com/photo-1536640712247-c45474762ef4?q=80&w=800'">
                </div>
                <div class="glass-card p-0 rounded-[40px] aspect-[3/4.2] overflow-hidden cursor-pointer group shadow-xl">
                    <img src="https://www.patpat.com/cdn/shop/files/01_5.jpg?v=1773137689" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt="Family 3" onerror="this.src='https://images.unsplash.com/photo-1491438590914-bc09fcaaf77a?q=80&w=800'">
                </div>
                <div class="glass-card p-0 rounded-[40px] aspect-[3/4.2] overflow-hidden cursor-pointer group shadow-xl">
                    <img src="https://www.patpat.com/cdn/shop/files/190809edf4244b35ab95369107bf4471.webp?v=1755141326" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt="Family 4" onerror="this.src='https://images.unsplash.com/photo-1502086223501-7ea244391501?q=80&w=800'">
