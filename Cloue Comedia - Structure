    <style>
        html {
            scroll-behavior: smooth;
        }
        body {
            font-family: 'Tenor Sans', sans-serif;
            background-color: #FDFCF8;
            color: #2D2D2D;
            -webkit-font-smoothing: antialiased;
        }
        .font-serif {
            font-family: 'Cormorant Garamond', serif;
        }
        .font-logo {
            font-family: 'Playfair Display', serif;
        }
        .font-footer {
            font-family: 'Montserrat', sans-serif;
        }
        /* REFINED OPAQUE GLASS EFFECT */
        .glass-card {
            background: rgba(255, 255, 255, 0.85); 
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 15px 35px -5px rgba(74, 59, 40, 0.08);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 25px 50px -10px rgba(74, 59, 40, 0.12);
        }
        .modal-hidden {
            display: none !important;
        }
        /* FABRIC BACKGROUND */
        .fabric-bg {
            background-image: url('https://plus.unsplash.com/premium_photo-1674747087104-516a4d6d316c?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }
        .fabric-overlay {
            background: rgba(253, 252, 248, 0.5);
        }
        /* SPECIALIZED GALLERY BACKGROUND */
        .gallery-overlay {
            background: radial-gradient(circle at center, rgba(253, 252, 248, 0.4) 0%, rgba(244, 239, 230, 0.3) 100%);
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 1s ease-out forwards;
        }
        .safe-blur-bg {
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
        }
    </style>
</head>
